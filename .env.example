# ─── oriz-finance specific ───────────────────────────────────────────────────
# Alpha Vantage — free-tier market data API used by /dashboard's
# <MarketDataChart /> island (forward-ref to oriz-kit). Free tier limits:
#   • 25 requests / day
#   • 5 requests / minute
# Caching strategy: every successful response is written to a CF KV store
# keyed by `<symbol>:<interval>` with a 12h TTL, so the daily quota covers
# all visitors. See ops/alpha-vantage-cache.md for the worker contract.
ALPHA_VANTAGE_API_KEY=
PUBLIC_ALPHA_VANTAGE_PROXY=https://av.oriz.workers.dev

# Astro PUBLIC_* mirrors used at build time by BaseLayout (Klaro consent,
# JSON-LD, status banner). These are public on purpose — they ship in the
# rendered HTML.
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=auth.oriz.in
PUBLIC_FIREBASE_PROJECT_ID=oriz-app
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
PUBLIC_CF_BEACON_TOKEN=
PUBLIC_ENABLE_CF_ANALYTICS=
PUBLIC_WEB3FORMS_KEY=
PUBLIC_BUTTONDOWN_USERNAME=chirag127
PUBLIC_GA4_ID=
# PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
PUBLIC_FUNDING_CHOICES_ID=

# Build perf
UV_THREADPOOL_SIZE=64
