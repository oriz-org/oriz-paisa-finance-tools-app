# --- Git host mirror (knowledge/decisions/architecture/mirror-to-4-git-hosts.md) ---
# Master cron pushes every submodule + master to these 4 hosts every Friday.
# Set as org-level GH secrets via `gh secret set --org chirag127 --visibility all`.
GITLAB_TOKEN=                     # gitlab.com → Settings → Access Tokens → write_repository
CODEBERG_TOKEN=                   # codeberg.org → Settings → Applications → write:repository
BITBUCKET_APP_PASSWORD=           # bitbucket.org → Personal settings → App passwords → Repositories: write
GITFLIC_TOKEN=                    # gitflic.ru → Settings → Tokens → repo:write (sanctions-aware)

# --- Telegram notifications (single channel for all 41 repos) ---
# Receive: release, CI failure, security alert, mirror push status, weekly digest.
TELEGRAM_BOT_TOKEN=               # @BotFather on Telegram → /newbot
TELEGRAM_CHAT_ID=                 # add bot to group → @userinfobot → chat id

# --- OSS programs unlocked by MIT switch (knowledge/decisions/architecture/mit-license-all-repos.md) ---
# Apply per project at the URLs in knowledge/services/easy-free-tier.md.
SENTRY_DSN=                       # per project; apply at sentry.io/for/open-source for OSS plan
SENTRY_AUTH_TOKEN=                # release tracking
BROWSERSTACK_USERNAME=            # apply at browserstack.com/open-source
BROWSERSTACK_ACCESS_KEY=
SAUCELABS_USERNAME=               # apply at saucelabs.com/open-source
SAUCELABS_ACCESS_KEY=
LAMBDATEST_USERNAME=              # apply at lambdatest.com/open-source-projects
LAMBDATEST_ACCESS_KEY=
FOSSA_API_KEY=                    # auto on sign-in at fossa.com (MIT auto-detected)
SNYK_TOKEN=                       # automatic on connect (public repos = unlimited)
GITGUARDIAN_API_KEY=              # automatic on install of GH App
DATADOG_API_KEY=                  # apply at opensource.datadoghq.com/projects/oss-program
DATADOG_APP_KEY=
CROWDIN_PROJECT_ID=               # per project; apply at crowdin.com/page/open-source-project-setup-request
CROWDIN_PERSONAL_TOKEN=
