---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { SITE_CONFIG } from '~/lib/siteConfig'
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? ''
---

<BaseLayout
  title={`Contact — ${SITE_CONFIG.name}`}
  description={`Get in touch about ${SITE_CONFIG.name} on oriz.`}
>
  <header class="container-prose page-head">
    <p class="eyebrow"><a href="/">{SITE_CONFIG.name}</a> / Contact</p>
    <h1>Contact</h1>
  </header>

  <section class="container-prose prose">
    <p class="lede">
      Spotted a calculation that looks off? A formula you want documented? An
      EMI scenario this site doesn't yet handle? Tell me — calculator
      correctness is the whole point of {SITE_CONFIG.name}.
    </p>
    <p>
      Email is fastest:
      <a href="mailto:whyiswhen@gmail.com"><strong>whyiswhen@gmail.com</strong></a>.
      Otherwise the form below posts to Web3Forms which forwards to my inbox.
      No data is stored on this site.
    </p>

    <form action="https://api.web3forms.com/submit" method="POST" class="contact-form">
      <input type="hidden" name="access_key" value={web3formsKey} />
      <input type="hidden" name="from_name" value={`${SITE_CONFIG.name} contact form`} />
      <input type="text" name="botcheck" class="hp" tabindex="-1" autocomplete="off" />

      <label class="field">
        <span>Your name</span>
        <input type="text" name="name" required autocomplete="name" />
      </label>
      <label class="field">
        <span>Email</span>
        <input type="email" name="email" required autocomplete="email" />
      </label>
      <label class="field">
        <span>Subject</span>
        <input type="text" name="subject" required />
      </label>
      <label class="field">
        <span>Message</span>
        <textarea name="message" rows="6" required></textarea>
      </label>

      <button type="submit" class="btn-primary">Send</button>
    </form>

    <p class="meta">
      For privacy questions or DMCA notices, see the
      <a href="/legal/grievance/">grievance officer</a> page (mandatory under IT Rules 2021).
    </p>
  </section>
</BaseLayout>

<style>
  .page-head { padding-block: 3rem 1.5rem; border-bottom: 1px solid var(--color-border); }
  .eyebrow { color: var(--color-fg-muted); font-size: 0.8125rem; margin: 0 0 0.5rem; }
  .eyebrow a { color: var(--color-fg-muted); text-decoration: none; }
  h1 { font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 600; letter-spacing: -0.02em; margin: 0; }
  .prose { padding-block: 2.5rem 4rem; color: var(--color-prose); line-height: 1.7; font-size: 1.0625rem; }
  .prose .lede { font-size: 1.1875rem; color: var(--color-fg); margin: 0 0 1.5rem; }
  .prose a { color: var(--color-accent); }
  .contact-form { display: flex; flex-direction: column; gap: 1rem; margin-block: 2rem; }
  .field { display: flex; flex-direction: column; gap: 0.375rem; }
  .field span { font-size: 0.875rem; color: var(--color-fg-muted); font-weight: 500; }
  .field input, .field textarea {
    padding: 0.625rem 0.875rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-button);
    color: var(--color-fg); font-family: inherit; font-size: 1rem;
  }
  .field input:focus, .field textarea:focus {
    outline: none;
    border-color: color-mix(in oklab, var(--color-accent) 60%, var(--color-border));
  }
  .field textarea { resize: vertical; min-height: 120px; }
  .hp { position: absolute; left: -9999px; opacity: 0; }
  .btn-primary {
    align-self: flex-start; height: 44px; padding-inline: 1.5rem;
    background: var(--color-accent); color: var(--color-accent-fg);
    border: 0; border-radius: var(--radius-button);
    font-family: inherit; font-size: 1rem; font-weight: 500; cursor: pointer;
  }
  .meta { font-size: 0.875rem; color: var(--color-fg-muted); margin-top: 2rem; }
</style>
