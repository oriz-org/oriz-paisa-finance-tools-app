---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { SITE_CONFIG } from '~/lib/siteConfig'

const updated = '2026-06-19'
---

<BaseLayout title={`Cookie policy — ${SITE_CONFIG.name}`} description={`What cookies ${SITE_CONFIG.name} uses.`}>
  <header class="container-prose page-head">
    <p class="eyebrow"><a href="/">{SITE_CONFIG.name}</a> / <a href="/legal/">Legal</a> / Cookies</p>
    <h1>Cookie policy</h1>
    <p class="meta">Last updated: {updated}</p>
  </header>

  <article class="container-prose prose">
    <p>
      {SITE_CONFIG.name} uses the smallest set of cookies and storage we can
      get away with.
    </p>

    <h2>What we set</h2>
    <ul>
      <li>
        <strong>Theme + accent</strong> — <code>localStorage</code> keys
        <code>oriz:theme</code> and <code>oriz:accent</code> remember your
        preference between visits. No tracking.
      </li>
      <li>
        <strong>Auth session</strong> — when you sign in, Firebase Authentication
        sets cookies on <code>auth.oriz.in</code> so you stay logged in across
        every <code>*.oriz.in</code> site. These are first-party and essential.
      </li>
      <li>
        <strong>Calculator drafts</strong> — calculators may use
        <code>localStorage</code> to remember your last inputs so a refresh
        does not lose work. These never leave your device.
      </li>
    </ul>

    <h2>Third parties</h2>
    <ul>
      <li>
        <strong>Cloudflare</strong> may set anti-abuse cookies (Turnstile, bot
        management). These are essential for site availability.
      </li>
      <li>
        <strong>Google AdSense</strong> (once approved) may set advertising
        cookies. The consent banner lets you opt out per-purpose.
      </li>
    </ul>

    <h2>Opting out</h2>
    <p>
      You can clear localStorage and cookies for <code>{SITE_CONFIG.origin.replace('https://', '')}</code>
      from your browser's site-data settings. Theme, auth, and any calculator
      drafts will reset to defaults.
    </p>
  </article>
</BaseLayout>

<style>
  .page-head { padding-block: 3rem 1.5rem; border-bottom: 1px solid var(--color-border); }
  .eyebrow { color: var(--color-fg-muted); font-size: 0.8125rem; margin: 0 0 0.5rem; }
  .eyebrow a { color: var(--color-fg-muted); text-decoration: none; }
  h1 { font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 600; letter-spacing: -0.02em; margin: 0; }
  .meta { color: var(--color-fg-soft); font-size: 0.875rem; margin: 0.5rem 0 0; }
  .prose { padding-block: 2.5rem 4rem; color: var(--color-prose); line-height: 1.7; font-size: 1.0625rem; }
  .prose h2 { font-family: var(--font-serif); font-size: 1.375rem; font-weight: 600; color: var(--color-fg); margin: 2rem 0 1rem; }
  .prose ul { padding-left: 1.5rem; margin: 0 0 1.25rem; }
  .prose li { margin-bottom: 0.5rem; }
  .prose p { margin: 0 0 1.25rem; }
  .prose a { color: var(--color-accent); }
  .prose code { background: var(--color-bg-muted); padding: 0.125em 0.375em; border-radius: 0.25rem; font-size: 0.875em; }
</style>
