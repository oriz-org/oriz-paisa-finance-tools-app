---
/*
 * BaseLayout — per-app shell for oriz-finance.
 *
 * Sweep #5 revert (2026-06-22): Header is fully divergent per-app (restored
 * from f0676f6^ with its FOLIO/ISSUE strip + MultiSearch/StatusBanner).
 * Footer + Sidebar + BottomBar come from @chirag127/astro-chrome with
 * per-app slot content (AppSidebarContent + bottomBarActions).
 *
 * v2 graph-paper-light surface. Fonts: Fraunces (display, H1 only) +
 * Source Sans 3 (body) + JetBrains Mono (every numeric, mandatory tnum).
 */
import '~/styles/global.css'
import '~/styles/oriz-ui-overrides.css'
import '@chirag127/astro-shell/tokens.css'
import FamilyChrome from '@chirag127/astro-shell/components/FamilyChrome.astro'
import FamilySidebar from '@chirag127/astro-shell/components/FamilySidebar.astro'
import BottomBar from '@chirag127/astro-chrome/BottomBar.astro'
import ConsentBanner from '@chirag127/astro-chrome/ConsentBanner.astro'
import Footer from '@chirag127/astro-chrome/Footer.astro'
import Sidebar from '@chirag127/astro-chrome/Sidebar.astro'
import AppSidebarContent from '~/components/AppSidebarContent.astro'
import Header from '~/components/Header.astro'
import JsonLd from '~/components/JsonLd.astro'
import { bottomBarActions } from '~/data/bottombar-actions'
import { SITE_CONFIG } from '~/lib/siteConfig'

interface Props {
  title?: string
  description?: string
  canonical?: string
  noindex?: boolean
  /** Page-level JSON-LD blocks appended to the default Org+WebSite+Person triple. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
}

const {
  title = `${SITE_CONFIG.name} — ${SITE_CONFIG.tagline}`,
  description = SITE_CONFIG.description,
  canonical = `${SITE_CONFIG.origin}${Astro.url.pathname}`,
  noindex = false,
  jsonLd,
} = Astro.props

const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT
const beaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN
const cfAnalyticsEnabled = import.meta.env.PUBLIC_ENABLE_CF_ANALYTICS === 'true'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={`${SITE_CONFIG.name} — oriz`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@chirag127" />
    <meta name="theme-color" content="#F0F2EE" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="alternate" type="application/rss+xml" title="oriz · RSS" href="/rss.xml" />
    <link rel="alternate" type="application/atom+xml" title="oriz · Atom" href="/atom.xml" />
    <link rel="alternate" type="application/feed+json" title="oriz · JSON Feed" href="/feed.json" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,400..700,30..100&family=Source+Sans+3:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <JsonLd extra={jsonLd} pageUrl={canonical} />

    {
      adsenseClient && (
        <script
          is:inline
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
          crossorigin="anonymous"
        />
      )
    }

    {
      cfAnalyticsEnabled && beaconToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${beaconToken}"}`}
        />
      )
    }
  </head>
  <body>
    <FamilyChrome slug="oriz-paisa-finance-tools-app" title="Finance" accent="#1f6b4a" />
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <Sidebar>
      <AppSidebarContent />
    </Sidebar>
    <main id="main">
      <div class="oriz-shell">
        <FamilySidebar slug="oriz-paisa-finance-tools-app" title="Finance Tools">
          <a slot="tools" href="/calculators/sip/">SIP</a>
          <a slot="tools" href="/calculators/lumpsum/">Lumpsum</a>
          <a slot="tools" href="/calculators/step-up-sip/">Step-up SIP</a>
          <a slot="tools" href="/calculators/swp/">SWP</a>
          <a slot="tools" href="/calculators/cagr/">CAGR / XIRR</a>
          <a slot="tools" href="/calculators/goal-planner/">Goal planner</a>
          <a slot="tools" href="/calculators/fire/">FIRE</a>
          <a slot="tools" href="/calculators/home-loan-emi/">Home loan EMI</a>
          <a slot="tools" href="/calculators/car-loan/">Car loan</a>
          <a slot="tools" href="/calculators/personal-loan/">Personal loan</a>
          <a slot="tools" href="/calculators/prepayment-impact/">Prepayment impact</a>
          <a slot="tools" href="/calculators/loan-comparison/">Loan comparison</a>
          <a slot="tools" href="/calculators/eligibility-foir/">Eligibility / FOIR</a>
          <a slot="tools" href="/calculators/fd/">FD</a>
          <a slot="tools" href="/calculators/rd/">RD</a>
          <a slot="tools" href="/calculators/ppf/">PPF</a>
          <a slot="tools" href="/calculators/nps/">NPS</a>
          <a slot="tools" href="/calculators/nsc/">NSC</a>
          <a slot="tools" href="/calculators/ssy/">SSY</a>
          <a slot="tools" href="/calculators/compound-interest/">Compound interest</a>
          <a slot="tools" href="/calculators/savings-goal/">Savings goal</a>
          <a slot="tools" href="/calculators/take-home/">Take-home (CTC)</a>
          <a slot="tools" href="/calculators/tds/">TDS</a>
          <a slot="tools" href="/calculators/hra/">HRA exemption</a>
          <a slot="tools" href="/calculators/gratuity/">Gratuity</a>
          <a slot="tools" href="/calculators/leave-encashment/">Leave encashment</a>
          <a slot="tools" href="/calculators/gst/">GST</a>
          <a slot="tools" href="/calculators/income-tax/">Income tax</a>
        </FamilySidebar>
        <div class="oriz-main"><slot /></div>
      </div>
    </main>
    <Footer />
    <BottomBar actions={bottomBarActions} />
    <ConsentBanner />
  </body>
</html>
