---
/*
 * BaseLayout — single page shell for every oriz-finance route.
 *
 * v2 graph-paper-light surface. Fonts: Fraunces (display, H1 only) +
 * Source Sans 3 (body) + JetBrains Mono (every numeric, mandatory tnum).
 *
 * No theme picker — light/dark via prefers-color-scheme only. The dark
 * variant is a recessed inversion that keeps the graph grid visible.
 *
 * 2026-06-20 wiring (this commit):
 *   • Default <JsonLd> Organization + WebSite + Person triple in <head>.
 *   • Page-level `jsonLd` prop appends additional blocks (no replacement).
 *   • <FeedDiscovery /> link tags for /rss.xml + /atom.xml + /feed.json.
 *   • CF Web Analytics gated behind PUBLIC_ENABLE_CF_ANALYTICS=true.
 *   • <ConsentBanner /> mounted before </body> — Klaro lazy script.
 *   • Header now mounts <StatusBanner /> + <MultiSearch /> as React islands.
 */
import '~/styles/global.css'
import '~/styles/oriz-ui-overrides.css'
import ConsentBanner from '~/components/ConsentBanner.astro'
import Footer from '~/components/Footer.astro'
import Header from '~/components/Header.astro'
import JsonLd from '~/components/JsonLd.astro'
import { SITE_CONFIG } from '~/lib/siteConfig'

interface Props {
  title?: string
  description?: string
  canonical?: string
  noindex?: boolean
  /** Page-level JSON-LD blocks appended to the default Org+WebSite+Person triple. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
}

const {
  title = `${SITE_CONFIG.name} — ${SITE_CONFIG.tagline}`,
  description = SITE_CONFIG.description,
  canonical = `${SITE_CONFIG.origin}${Astro.url.pathname}`,
  noindex = false,
  jsonLd,
} = Astro.props

const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT
const beaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN
const cfAnalyticsEnabled = import.meta.env.PUBLIC_ENABLE_CF_ANALYTICS === 'true'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={`${SITE_CONFIG.name} — oriz`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@chirag127" />
    <meta name="theme-color" content="#F0F2EE" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/*
      Feed discovery — three formats per
      knowledge/decisions/architecture/feeds-rss-atom-json.md.
      Cross-link to canonical apex feeds (oriz.in) from every site.
    */}
    <link rel="alternate" type="application/rss+xml" title="oriz · RSS" href="/rss.xml" />
    <link rel="alternate" type="application/atom+xml" title="oriz · Atom" href="/atom.xml" />
    <link rel="alternate" type="application/feed+json" title="oriz · JSON Feed" href="/feed.json" />

    {/*
      Type stack — Fraunces (display, opsz 144 + soft -10), Source Sans 3
      (body), JetBrains Mono (numerics).
    */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,400..700,30..100&family=Source+Sans+3:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    {/* Default Organization + WebSite + Person triple. */}
    <JsonLd extra={jsonLd} pageUrl={canonical} />

    {
      adsenseClient && (
        <script
          is:inline
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
          crossorigin="anonymous"
        />
      )
    }

    {/* Cloudflare Web Analytics — cookie-less, gated by PUBLIC_ENABLE_CF_ANALYTICS. */}
    {
      cfAnalyticsEnabled && beaconToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${beaconToken}"}`}
        />
      )
    }
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main"><slot /></main>
    <Footer />
    <ConsentBanner />
  </body>
</html>
