---
import HeaderControls from '~/components/HeaderControls.tsx'
import { SITES } from '~/lib/sites'
import { SITE_CONFIG } from '~/lib/siteConfig'
---

<header class="site-header">
  <div class="container-page header-inner">
    <a href="/" class="brand" aria-label={`${SITE_CONFIG.name} — oriz`}>
      <span class="brand-mark">{SITE_CONFIG.name}</span>
      <span class="brand-dot">.</span>
      <span class="brand-family">oriz</span>
    </a>

    <nav aria-label="Primary" class="primary-nav">
      <a href="/">Home</a>
      <a href="/about/">About</a>
      <a href="/contact/">Contact</a>
    </nav>

    <HeaderControls client:idle sites={SITES} siteName={SITE_CONFIG.name} />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--color-bg) 85%, transparent);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--color-border);
  }
  .header-inner {
    height: 64px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .brand {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: var(--color-fg);
    line-height: 1;
    display: inline-flex;
    align-items: baseline;
    gap: 0.125rem;
  }
  .brand-dot { color: var(--color-accent); }
  .brand-family { color: var(--color-fg-soft); font-size: 0.9375rem; }
  .primary-nav {
    display: none;
    gap: 1.5rem;
    flex: 1;
    font-size: 0.9375rem;
  }
  .primary-nav a {
    color: var(--color-fg-muted);
    text-decoration: none;
  }
  .primary-nav a:hover { color: var(--color-fg); }
  @media (min-width: 768px) {
    .primary-nav { display: flex; }
  }
</style>
