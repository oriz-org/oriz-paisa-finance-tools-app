---
/*
 * <ConsentBanner /> — Klaro consent loader.
 *
 * Locked spec: knowledge/decisions/security/consent-management-multi-category.md
 *
 * What ships today:
 *   • The Klaro <script> + per-family config inlined below, defer-loaded.
 *   • TODO: gate by CF-IPCountry geo (EU/UK/CCPA only). Today we ship
 *     the script on every page; the geo router lives in a CF Worker
 *     that hasn't been deployed yet, so this is a placeholder.
 *
 * 5 categories × N services per the lock — see decision file for the map.
 *
 * Family-anchor: this is the local Klaro config until @chirag127/oriz-kit
 * exports a `<ConsentBanner>` helper. When the kit ships, swap to:
 *   ---
 *   import ConsentBanner from '@chirag127/oriz-kit/astro/ConsentBanner.astro'
 *   ---
 */
const KLARO_VERSION = '0.7.21'
const KLARO_SRC = `https://cdn.kiprotect.com/klaro/v${KLARO_VERSION}/klaro.js`

// 5 purposes locked by the consent decision.
const purposes = [
  { id: 'necessary', title: 'Strictly necessary' },
  { id: 'analytics', title: 'Analytics' },
  { id: 'marketing', title: 'Marketing' },
  { id: 'functional', title: 'Functional preferences' },
  { id: 'social', title: 'Social embeds' },
]

// Service map — see decisions/security/consent-management-multi-category.md.
const services = [
  { name: 'cloudflare-web-analytics', purposes: ['necessary'], cookies: [], default: true, required: true },
  { name: 'sentry', purposes: ['necessary'], cookies: [], default: true, required: true },
  { name: 'google-analytics', purposes: ['analytics'], cookies: [/^_ga/, /^_gid/, /^_gat/], default: false },
  { name: 'posthog', purposes: ['analytics'], cookies: [/^ph_/, /^posthog/], default: false },
  { name: 'microsoft-clarity', purposes: ['analytics', 'marketing'], cookies: [/^_clck/, /^_clsk/], default: false },
  { name: 'algolia-insights', purposes: ['analytics'], cookies: [/^_ALGOLIA/], default: false },
  { name: 'utm-persistence', purposes: ['marketing'], cookies: [/^oriz_utm/], default: false },
  { name: 'fcm-push', purposes: ['functional'], cookies: [], default: false },
  { name: 'theme-pref', purposes: ['functional'], cookies: [/^oriz_theme/], default: true },
  { name: 'lang-pref', purposes: ['functional'], cookies: [/^oriz_lang/], default: true },
  { name: 'giscus', purposes: ['social'], cookies: [/^giscus/], default: false },
  { name: 'bluesky-embed', purposes: ['social'], cookies: [/^bsky/], default: false },
]

const config = {
  version: 1,
  elementID: 'klaro',
  styling: { theme: ['light', 'top', 'wide'] },
  noAutoLoad: false,
  htmlTexts: true,
  embedded: false,
  groupByPurpose: true,
  storageMethod: 'localStorage',
  cookieName: 'oriz-klaro',
  cookieExpiresAfterDays: 365,
  default: false,
  mustConsent: false,
  acceptAll: true,
  hideDeclineAll: false,
  hideLearnMore: false,
  noticeAsModal: false,
  translations: {
    en: {
      consentNotice: {
        description:
          'We use a few small services to make this site work. Some are required (auth, basic analytics); others (marketing analytics, social embeds) are off until you opt in.',
        learnMore: 'Customise',
      },
      consentModal: {
        title: 'Privacy preferences',
        description: 'Pick which categories of cookies you allow. You can change this any time from the footer.',
      },
      privacyPolicyUrl: 'https://oriz.in/privacy',
    },
  },
  purposes,
  services,
}

// Convert the regex cookies in services into something serialisable to a
// data-* attribute — we pass JSON to the inline script, which then patches
// the regexes back in a Klaro-compatible shape.
const serializableConfig = {
  ...config,
  services: services.map((s) => ({
    ...s,
    cookies: s.cookies.map((c) => (c instanceof RegExp ? c.source : c)),
  })),
}
---

<!--
  Klaro consent manager — multi-category cookie banner.
  TODO: gate by CF-IPCountry (EU/UK/CCPA only) once the Worker geo router
  is deployed. Today we ship Klaro to every visitor.
-->
<div id="klaro" data-oriz-consent="root"></div>
<script
  is:inline
  type="application/json"
  id="oriz-klaro-config"
  set:html={JSON.stringify(serializableConfig)}
/>
<script is:inline>
  ;(() => {
    // Reconstruct RegExp cookies from the JSON source strings.
    const raw = document.getElementById('oriz-klaro-config')
    if (!raw) return
    try {
      const cfg = JSON.parse(raw.textContent || '{}')
      cfg.services = (cfg.services || []).map((s) => ({
        ...s,
        cookies: (s.cookies || []).map((c) => (typeof c === 'string' ? new RegExp(c) : c)),
      }))
      window.klaroConfig = cfg
    } catch (e) {
      console.warn('oriz-klaro: bad config', e)
    }
  })()
</script>
<script is:inline defer src={KLARO_SRC} data-config="klaroConfig"></script>
